# ─── Database (Supabase PostgreSQL) ─────────────────────
# Get these from: https://supabase.com → Project Settings → Database
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# ─── Supabase (Real-time) ──────────────────────────────
# Get these from: https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# ─── Auth (NextAuth.js) ────────────────────────────────
# Generate a secret: openssl rand -base64 32
AUTH_SECRET="your-generated-secret-here"
AUTH_URL="http://localhost:3000"

# ─── App ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Børsbar"
